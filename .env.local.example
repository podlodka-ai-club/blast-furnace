# Copy this file to .env.local and replace the placeholder values.
# Load it into your current shell with:
#   source ./scripts/load-env.sh

export GITHUB_TOKEN='replace-with-github-token'
export GITHUB_OWNER='replace-with-github-owner'
export GITHUB_REPO='replace-with-github-repo'

export GITHUB_POLL_INTERVAL_MS='30000'

export CODEX_CLI_PATH='/opt/homebrew/bin/codex'
export CODEX_MODEL='gpt-5.4'
export CODEX_TIMEOUT_MS='300000'

export PORT='3000'
export REDIS_HOST='localhost'
export REDIS_PORT='6379'
